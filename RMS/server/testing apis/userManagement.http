@basePath = http://localhost:8000
@apiPath = {{basePath}}/api

POST {{apiPath}}/users

Content-Type: application/json

{
  "username": "john_doe",
  "password_hash": "securePassword123",
  "role": "Manager",
  "fullName": "John Doe",
  "email": "john.doe@example.com",
  "mobileNo": "9876543210",
  "address": "123 Business Street, City, State"
}
###post api for artist example
POST {{apiPath}}/users

Content-Type: application/json

{
  "username": "artist_anna",
  "password_hash": "password123",
  "role": "Artist",
  "fullName": "Anna Smith",
  "email": "anna.smith@example.com",
  "mobileNo": "8765432109",
  "address": "456 Creative Avenue, City, State",
  "genres": ["Pop", "Jazz"],
  "albums": ["album1", "album2"]
}

###get all users

GET {{apiPath}}/users/role/Manager

###get user by username

GET {{apiPath}}/users/aditya

###update user by id

PUT {{apiPath}}/users/aditya
Content-Type: application/json

{
  "mobileNo":7032804237
}

###delete user by id

DELETE {{apiPath}}/users/aditya

